# ── AI — odpowiedzi tekstowe ──────────────────

async def ai_odpowiedz(update: Update, context: ContextTypes.DEFAULT_TYPE):
user = update.effective_user
tekst = update.message.text

```
if user.id not in chat_history:
    chat_history[user.id] = []

chat_history[user.id].append({"role": "user", "content": tekst})

if len(chat_history[user.id]) > 10:
    chat_history[user.id] = chat_history[user.id][-10:]

await context.bot.send_chat_action(
    chat_id=update.effective_chat.id, action="typing"
)

try:
    response = groq_client.chat.completions.create(
        model="llama3-8b-8192",
        max_tokens=300,
        messages=[{"role": "system", "content": SYSTEM_PROMPT}] + chat_history[user.id],
    )
    odpowiedz = response.choices[0].message.content
    chat_history[user.id].append({"role": "assistant", "content": odpowiedz})

    await update.message.reply_text(odpowiedz, reply_markup=kb_po_ai())

except Exception as e:
    logger.error(f"Groq error: {e}")
    await update.message.reply_text(
        "Przepraszam, coś poszło nie tak. Spróbuj ponownie lub napisz /start",
        reply_markup=kb_glowna()
    )
```

# ── Start ──────────────────────────────────────

def main():
app = Application.builder().token(BOT_TOKEN).build()
app.add_handler(CommandHandler(“start”, start))
app.add_handler(CommandHandler(“kup”,   kup_cmd))
app.add_handler(CommandHandler(“menu”,  start))
app.add_handler(CallbackQueryHandler(przycisk))
app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, ai_odpowiedz))
logger.info(“✅ Bot uruchomiony!”)
app.run_polling(allowed_updates=Update.ALL_TYPES)

if **name** == “**main**”:
main()
